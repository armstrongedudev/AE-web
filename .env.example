# ===========================================================================
# Armstrong Educational Services — environment variables (TEMPLATE)
# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in the values:
#     cp .env.example .env.local
#
# RULES
#   • Variables prefixed with VITE_ are exposed to the BROWSER (public, safe).
#   • Everything WITHOUT the VITE_ prefix is SERVER-ONLY — used by the Vercel
#     serverless functions in /api. Never expose these to the client.
#   • Real secrets live in .env.local (gitignored) and in the Vercel dashboard.
# ===========================================================================

# ---- App -------------------------------------------------------------------
VITE_APP_URL=http://localhost:5180            # public site URL (prod: https://yourdomain.com)
CAMILLE_NOTIFY_EMAIL=                          # inbox that gets new-booking / contact alerts

# ---- Supabase — database + auth -------------------------------------------
# Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=                             # https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=                        # public "anon" key (safe in browser)
SUPABASE_SERVICE_ROLE_KEY=                     # SECRET — full DB access, server only

# ---- Auth providers --------------------------------------------------------
# These are configured in the Supabase dashboard
#   (Authentication → Providers) — you paste the IDs/secrets THERE, not here.
# Collect:
#   • Google     → Google Cloud → OAuth client (Client ID + Secret)
#   • Microsoft  → Azure AD → App registration (Client ID + Secret + Tenant)
#   • Apple      → Apple Developer → Service ID + Key (.p8) + Team ID + Key ID
#   • Email/password → enabled natively in Supabase (no keys needed)

# ---- Google Calendar API — bookings ---------------------------------------
# Google Cloud → enable "Google Calendar API" → create a Service Account →
# share Camille's calendar with the service-account email (permission:
# "Make changes to events").
GOOGLE_CALENDAR_ID=                            # Camille's calendar id (e.g. camille@gmail.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=                  # xxxx@xxxx.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=            # "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Resend — transactional email -----------------------------------------
# resend.com → API Keys, and verify your sending domain (SPF/DKIM)
RESEND_API_KEY=
RESEND_FROM_EMAIL=                             # e.g. Armstrong Education <hello@yourdomain.com>

# ===========================================================================
# FUTURE (not enabled yet — uncomment when you add them)
# ---------------------------------------------------------------------------
# Stripe (payments: self-paced courses, annual packs, school licenses)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# VITE_STRIPE_PUBLISHABLE_KEY=
#
# Anthropic Claude (AI quiz / chat assistant)
# ANTHROPIC_API_KEY=
# ===========================================================================
